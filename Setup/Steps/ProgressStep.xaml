<UserControl x:Class="WinDockSetup.Steps.ProgressStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerLine"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="0.75"
                             Duration="0:0:1.2" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Row 0: Header (Title & Status stacked) -->
            <RowDefinition Height="Auto"/> <!-- Row 1: Glowing Progress Bar Card -->
            <RowDefinition Height="*"/>    <!-- Row 2: Terminal Console Log -->
            <RowDefinition Height="Auto"/> <!-- Row 3: Action Buttons -->
        </Grid.RowDefinitions>

        <!-- Row 0: Step Header Stack (prevents text overlap) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="TitleText"
                       Text="Installing WinDock"
                       FontFamily="{StaticResource DisplayFontFamily}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource FogWhiteBrush}"
                       Margin="0,0,0,6"/>

            <TextBlock x:Name="StatusText"
                       Text="Preparing installation directory..."
                       FontFamily="{StaticResource BodyFontFamily}"
                       FontSize="13.5"
                       Foreground="{StaticResource FogWhite70Brush}"/>
        </StackPanel>

        <!-- Row 1: Glowing Progress Bar Card -->
        <Border Grid.Row="1"
                Background="{StaticResource FrostPanelBackgroundBrush}"
                BorderBrush="{StaticResource FrostPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,14"
                Margin="0,0,0,20">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="INSTALLATION PROGRESS"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="9.5"
                               FontWeight="Bold"
                               Foreground="{StaticResource FogWhite45Brush}"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="PercentText"
                               Text="0%"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TelemetryCyanBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>

                <Grid x:Name="ProgressTrackContainer" Height="6">
                    <!-- Progress Track -->
                    <Border CornerRadius="3" Background="#1AFFFFFF"/>
                    <!-- Progress Fill -->
                    <Border x:Name="ProgressBarFill"
                            HorizontalAlignment="Left"
                            Width="0"
                            CornerRadius="3"
                            Background="{StaticResource TelemetryCyanBrush}"/>
                    <!-- Shimmer Glow Line -->
                    <Rectangle x:Name="ShimmerLine"
                               Height="6"
                               Fill="{StaticResource TelemetryCyanBrush}"
                               Opacity="0.4"
                               RadiusX="3" RadiusY="3"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 2: Terminal Console Log -->
        <Border Grid.Row="2"
                Background="#0A000000"
                BorderBrush="{StaticResource FrostPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,12"
                Margin="0,0,0,16">
            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="LogText"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource FogWhite45Brush}"
                           TextWrapping="Wrap"
                           LineHeight="18"/>
            </ScrollViewer>
        </Border>

        <!-- Row 3: Action Buttons Row -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Button x:Name="CancelBtn"
                    Content="Cancel"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Left"
                    Click="CancelBtn_Click"/>

            <Button x:Name="RetryBtn"
                    Content="Retry Installation"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    Click="RetryBtn_Click"
                    Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>
