<Window x:Class="WinDockSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinDock Setup" 
        Height="420" Width="520"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Custom CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" BorderThickness="1.2" BorderBrush="#3F3F3F" Margin="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#ED222222" Offset="0.0"/>
                <GradientStop Color="#F4141414" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.65" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Drag Titlebar -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleBarText" Text="WinDock Setup" Foreground="#A0A0A0" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="16,0,0,0"/>
                <Button Content="✕" Foreground="#A0A0A0" Background="Transparent" BorderBrush="Transparent" FontSize="14" FontWeight="Bold" Width="36" Height="36" VerticalAlignment="Center" HorizontalAlignment="Right" Click="CloseButton_Click" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#33FF3333"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Main Panel -->
            <Grid Grid.Row="1" Margin="24,8,24,24">
                <!-- Welcome State -->
                <StackPanel x:Name="WelcomePanel" Visibility="Visible" VerticalAlignment="Center">
                    <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Image Source="windock_logo.png" Stretch="Uniform"/>
                    </Grid>
                    
                    <TextBlock x:Name="TitleText" Text="Install WinDock" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SubtitleText" Text="Liquid Glass dock, macOS-style Spotlight, widgets, and desktop polish." Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,16"/>
                    
                    <!-- Path Picker Panel -->
                    <StackPanel x:Name="PathPanel" Margin="0,0,0,14" HorizontalAlignment="Center" Width="380">
                        <TextBlock Text="INSTALLATION LOCATION" Foreground="#888888" FontSize="9.5" FontWeight="Bold" Margin="4,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InstallPathTextBox" Grid.Column="0" Height="30" Foreground="White" Background="#1C1C1E" BorderBrush="#3A3A3C" BorderThickness="1.2" VerticalContentAlignment="Center" Padding="8,0,8,0" FontSize="12">
                                <TextBox.Resources>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button Grid.Column="1" Content="Browse..." Width="76" Height="30" Margin="8,0,0,0" Click="BrowseButton_Click" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="btnBorder" CornerRadius="6" Background="#262629" BorderBrush="#3A3A3C" BorderThickness="1">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="btnBorder" Property="Background" Value="#3A3A3C"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Options Grid -->
                    <Grid x:Name="OptionsPanel" Width="380" HorizontalAlignment="Center" Margin="0,4,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="ShortcutCheckbox" Grid.Column="0" Content="Create Desktop Shortcut" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <CheckBox x:Name="StartupCheckbox" Grid.Column="1" Content="Launch on Startup" IsChecked="True" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- Action Button -->
                    <Button x:Name="ActionButton" Content="Install WinDock" Width="180" Height="38" Click="ActionButton_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder" CornerRadius="19">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#00D2FF" Offset="0.0"/>
                                                        <GradientStop Color="#0078FF" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#30D5FF" Offset="0.0"/>
                                                                <GradientStop Color="#208CFF" Offset="1.0"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Installing State -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Image Source="windock_logo.png" Stretch="Uniform"/>
                    </Grid>
                    
                    <TextBlock x:Name="StatusText" Text="Installing WinDock..." Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    
                    <ProgressBar x:Name="InstallProgressBar" Minimum="0" Maximum="100" Value="15" Height="8" Width="320" HorizontalAlignment="Center" BorderThickness="0" Background="#33FFFFFF" Foreground="#00D2FF">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Grid x:Name="TemplateRoot">
                                    <Border CornerRadius="4" Background="{TemplateBinding Background}"/>
                                    <Border CornerRadius="4" x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left"/>
                                </Grid>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </StackPanel>

                <!-- Complete State -->
                <StackPanel x:Name="CompletePanel" Visibility="Collapsed" VerticalAlignment="Center">
                    <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Image Source="windock_logo.png" Stretch="Uniform"/>
                    </Grid>
                    
                    <TextBlock Text="WinDock Setup Complete" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="WinDock was successfully installed." Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <Button Content="Launch WinDock" Width="180" Height="38" Click="LaunchButton_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnBorder" CornerRadius="19">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#00E676" Offset="0.0"/>
                                                        <GradientStop Color="#00B0FF" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnBorder" Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#33F08B" Offset="0.0"/>
                                                                <GradientStop Color="#33C0FF" Offset="1.0"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
