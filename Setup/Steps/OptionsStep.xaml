<UserControl x:Class="WinDockSetup.Steps.OptionsStep"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="600"
             Background="Transparent">
             
    <UserControl.Resources>
        <ControlTemplate TargetType="CheckBox" x:Key="ToggleSwitchStyle">
            <StackPanel Orientation="Horizontal" Background="Transparent" Cursor="Hand">
                <Grid Width="38" Height="20">
                    <Border x:Name="TrackOff" CornerRadius="10" Background="{StaticResource FrostPanelBackgroundBrush}" BorderBrush="{StaticResource FrostPanelBorderBrush}" BorderThickness="1" />
                    <Border x:Name="TrackOn" CornerRadius="10" Background="{StaticResource TelemetryCyanBrush}" BorderThickness="0" Opacity="0" />
                    <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="{StaticResource FogWhiteBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
                <TextBlock Text="{TemplateBinding Content}" FontFamily="{StaticResource BodyFontFamily}" FontSize="13.5" Foreground="{StaticResource FogWhiteBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
            </StackPanel>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="18" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase Amplitude="0.08" EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="TrackOn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="Thumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15">
                                    <DoubleAnimation.EasingFunction>
                                        <BackEase Amplitude="0.08" EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="TrackOn" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter TargetName="TrackOn" Property="Opacity" Value="1" />
                    <Setter TargetName="Thumb" Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform X="18" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <TextBlock Text="Installation Options" FontFamily="{StaticResource DisplayFontFamily}" FontSize="20" Foreground="{StaticResource FogWhiteBrush}" Margin="0,0,0,30" />
        
        <StackPanel Grid.Row="1">
            <TextBlock Text="Install location" FontFamily="{StaticResource BodyFontFamily}" FontSize="13" Foreground="{StaticResource FogWhite70Brush}" Margin="0,0,0,8" />
            
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="PathTextBox" 
                         FontFamily="{StaticResource MonoFontFamily}" FontSize="12.5" Foreground="{StaticResource FogWhiteBrush}"
                         Background="{StaticResource FrostPanelBackgroundBrush}" BorderBrush="{StaticResource FrostPanelBorderBrush}"
                         BorderThickness="1" Padding="12,10" VerticalContentAlignment="Center" TextChanged="PathTextBox_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                
                <Button Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource GhostButtonStyle}" Content="Browse..." Click="BrowseButton_Click" />
            </Grid>
            
            <TextBlock x:Name="DiskSpaceTextBlock" FontFamily="{StaticResource MonoFontFamily}" FontSize="11" Foreground="{StaticResource FogWhite45Brush}" Margin="0,0,0,30" />
            
            <StackPanel>
                <CheckBox x:Name="StartupToggle" Content="Launch WinDock at startup" Template="{StaticResource ToggleSwitchStyle}" IsChecked="True" Margin="0,0,0,16" />
                <CheckBox x:Name="StartMenuToggle" Content="Add Start Menu shortcut" Template="{StaticResource ToggleSwitchStyle}" IsChecked="True" Margin="0,0,0,16" />
                <CheckBox x:Name="DesktopShortcutToggle" Content="Add Desktop shortcut" Template="{StaticResource ToggleSwitchStyle}" IsChecked="False" Margin="0,0,0,16" />
                <CheckBox x:Name="UpdatesToggle" Content="Check for updates automatically" Template="{StaticResource ToggleSwitchStyle}" IsChecked="True" />
            </StackPanel>
        </StackPanel>
        
        <Grid Grid.Row="2" Margin="0,30,0,0">
            <Button HorizontalAlignment="Left" Style="{StaticResource GhostButtonStyle}" Content="← Back" Click="BackButton_Click" />
            
            <Button HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}" Content="Install" Click="InstallButton_Click" />
        </Grid>
    </Grid>
</UserControl>
