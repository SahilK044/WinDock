<Window x:Class="WinDockSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Height="520"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Border CornerRadius="12"
            BorderThickness="1"
            Margin="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#CC0A0C0E" Offset="0"/>
                <GradientStop Color="#E6050608" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                <GradientStop Color="#1A35D6C7" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="3" Opacity="0.6" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="38"/>
            </Grid.RowDefinitions>

            <!-- Row 0 — Title Bar -->
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="#05FFFFFF">
                <!-- Centered Title -->
                <TextBlock Text="W I N D O C K   S E T U P" 
                           FontFamily="{StaticResource DisplayFontFamily}" 
                           FontSize="10" 
                           FontWeight="Bold"
                           Foreground="{StaticResource FogWhite45Brush}"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>

                <!-- Window controls -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <!-- Minimize -->
                    <Button x:Name="MinBtn" Click="MinBtn_Click"
                            Width="30" Height="30"
                            Foreground="{StaticResource FogWhite45Brush}"
                            FontSize="14"
                            Content="–">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1Affffff"/>
                                        <Setter Property="Foreground" Value="{StaticResource FogWhiteBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Close -->
                    <Button x:Name="CloseBtn" Click="CloseBtn_Click"
                            Width="30" Height="30"
                            Foreground="{StaticResource FogWhite45Brush}"
                            FontSize="11"
                            Content="✕">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="0,1,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#E3483D"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Row 1 — Content Area -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Step dots -->
                <StackPanel x:Name="StepDotsPanel" Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,0">
                    <Ellipse x:Name="StepDot1" Width="6" Height="6" Fill="{StaticResource TelemetryCyanBrush}"  Margin="0,0,8,0"/>
                    <Ellipse x:Name="StepDot2" Width="6" Height="6" Fill="#26ffffff" Margin="0,0,8,0"/>
                    <Ellipse x:Name="StepDot3" Width="6" Height="6" Fill="#26ffffff" Margin="0,0,8,0"/>
                    <Ellipse x:Name="StepDot4" Width="6" Height="6" Fill="#26ffffff" Margin="0,0,8,0"/>
                </StackPanel>

                <!-- Step content host -->
                <ContentControl x:Name="StepHost"
                                Grid.Row="1"
                                Margin="40,24,40,24"/>
            </Grid>

            <!-- Row 2 — Telemetry Strip -->
            <Border Grid.Row="2"
                    Height="38"
                    Background="#0DFFFFFF"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12">
                <Grid>
                    <!-- Progress fill (behind text) -->
                    <Border x:Name="TelemetryFill"
                            HorizontalAlignment="Left"
                            Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0035D6C7" Offset="0"/>
                                <GradientStop Color="#1035D6C7" Offset="0.7"/>
                                <GradientStop Color="#2C35D6C7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Text container -->
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left label -->
                        <TextBlock x:Name="TelemetryAction"
                                   Grid.Column="0"
                                   Text="WINDOCK SETUP v1.0"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="10.5"
                                   Foreground="{StaticResource FogWhite45Brush}"
                                   VerticalAlignment="Center"/>

                        <!-- Right label -->
                        <TextBlock x:Name="TelemetryDetail"
                                   Grid.Column="1"
                                   Text="READY"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="10.5"
                                   Foreground="{StaticResource FogWhite45Brush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
