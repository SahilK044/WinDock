<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         DESIGN TOKENS  ·  WinDock Setup
         All colours, brushes, typography, radii, and control styles.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Brush Tokens ─────────────────────────────────────────────── -->

    <!-- Base window background — Graphite Void -->
    <SolidColorBrush x:Key="GraphiteVoidBrush"          Color="#0D0F12"/>

    <!-- Frost-glass panel -->
    <SolidColorBrush x:Key="FrostPanelBackgroundBrush"  Color="#0Dffffff"/>
    <SolidColorBrush x:Key="FrostPanelBorderBrush"      Color="#17ffffff"/>

    <!-- Primary accent — Telemetry Cyan -->
    <SolidColorBrush x:Key="TelemetryCyanBrush"         Color="#35D6C7"/>
    <SolidColorBrush x:Key="TelemetryCyan26Brush"       Color="#2635D6C7"/>

    <!-- Success / finish — Podium Gold -->
    <SolidColorBrush x:Key="PodiumGoldBrush"            Color="#E8B84B"/>

    <!-- Cancel / errors — Signal Red -->
    <SolidColorBrush x:Key="SignalRedBrush"             Color="#E3483D"/>

    <!-- Text hierarchy — Fog White at 100 / 70 / 45% -->
    <SolidColorBrush x:Key="FogWhiteBrush"              Color="#EDEFF2"/>
    <SolidColorBrush x:Key="FogWhite70Brush"            Color="#B3B6BA"/>
    <SolidColorBrush x:Key="FogWhite45Brush"            Color="#6B6E73"/>

    <!-- Hover overlays -->
    <SolidColorBrush x:Key="HoverOverlayBrush"          Color="#1Affffff"/>
    <SolidColorBrush x:Key="PressOverlayBrush"          Color="#26ffffff"/>

    <!-- ── Color Tokens (for ColorAnimation.To) ──────────────────── -->

    <Color x:Key="TelemetryCyanColor">#35D6C7</Color>
    <Color x:Key="PodiumGoldColor">#E8B84B</Color>
    <Color x:Key="SignalRedColor">#E3483D</Color>
    <Color x:Key="GraphiteVoidColor">#0D0F12</Color>
    <Color x:Key="FogWhiteColor">#EDEFF2</Color>
    <Color x:Key="FrostPanelBgColor">#0Dffffff</Color>
    <Color x:Key="StepDotInactiveColor">#26ffffff</Color>

    <!-- ── Typography ───────────────────────────────────────────────── -->

    <FontFamily x:Key="DisplayFontFamily">Titillium Web, Segoe UI</FontFamily>
    <FontFamily x:Key="BodyFontFamily">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">JetBrains Mono, Consolas</FontFamily>

    <!-- ── Corner Radii ─────────────────────────────────────────────── -->

    <CornerRadius x:Key="WindowCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="ToggleCornerRadius">10</CornerRadius>
    <CornerRadius x:Key="InputCornerRadius">6</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Primary Action Button ──────────────────────────────────── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource TelemetryCyanBrush}"/>
        <Setter Property="Foreground" Value="#0D0F12"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="24,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                         To="1.03" Duration="0:0:0.120">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                         To="1.03" Duration="0:0:0.120">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                         To="1.0" Duration="0:0:0.120">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                         To="1.0" Duration="0:0:0.120">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                         To="0.97" Duration="0:0:0.080">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                         To="0.97" Duration="0:0:0.080">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Ghost / Secondary Button ───────────────────────────────── -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FogWhite45Brush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource FogWhite70Brush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource PressOverlayBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Styled TextBox (for path input) ────────────────────────── -->
    <Style x:Key="FrostTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource FrostPanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FogWhiteBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FrostPanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CaretBrush" Value="{StaticResource TelemetryCyanBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource TelemetryCyanBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource InputCornerRadius}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource TelemetryCyanBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Custom CheckBox (Finish step) ──────────────────────────── -->
    <Style x:Key="CyanCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource FogWhiteBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box"
                                Width="18" Height="18"
                                CornerRadius="4"
                                BorderThickness="1.5"
                                BorderBrush="{StaticResource FrostPanelBorderBrush}"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                            <Path x:Name="Check"
                                  Data="M 3,9 L 7,13 L 14,5"
                                  Stroke="{StaticResource GraphiteVoidBrush}"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Opacity="0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource TelemetryCyanBrush}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource TelemetryCyanBrush}"/>
                            <Setter TargetName="Check" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource FogWhite45Brush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
